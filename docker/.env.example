# =============================================================================
# Docker Compose Environment Configuration
# =============================================================================
# This file contains environment variables for docker-compose
# Copy this to .env in the docker/ directory and update with your values
# =============================================================================

# -----------------------------------------------------------------------------
# Security - CRITICAL: Change these in production!
# -----------------------------------------------------------------------------

# JWT Secret - Generate with: openssl rand -hex 32
# MUST be at least 32 characters
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION_MIN_32_CHARS

# MongoDB Password
# Generate with: openssl rand -base64 24
MONGO_PASSWORD=pinnacle_secure_pass_2026

# Comma-separated frontend origins allowed by backend CORS
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# 1. The JWT_SECRET default in docker-compose.yml will trigger a warning
# 2. Always set unique passwords for production deployments
# 3. Never commit this file with real credentials to version control
# 4. Use secrets management for production (e.g., Docker Secrets, Vault)
