# Backend environment configuration
MONGO_URL=mongodb://127.0.0.1:27017/pinnacle
DB_NAME=pinnacle
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRY_HOURS=24
# Comma-separated allowed origins for browser clients
CORS_ORIGINS=http://localhost:3000

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Public frontend base URL used by checkout success/cancel redirects
FRONTEND_URL=http://localhost:3000
